# ─────────────────────────────────────────
# SK Framework — Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────

# ─── LLM API Keys (add the ones you want to use) ───
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ─── Default Target Model ───
# Used when --target is not specified in CLI
SK_DEFAULT_PROVIDER=openai
SK_DEFAULT_MODEL=gpt-4o

# ─── API Server ───
SK_API_HOST=0.0.0.0
SK_API_PORT=8000
SK_API_DEBUG=false

# ─── Database ───
# SQLite path for session/results storage
SK_DB_PATH=./data/sk_sessions.db

# ─── Logging ───
SK_LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
SK_LOG_FORMAT=json         # json | text

# ─── Lab Settings ───
SK_LAB_TIMEOUT_SECONDS=300 # Max time per lab attempt
SK_LAB_MAX_ATTEMPTS=10     # Max attempts before lockout

# ─── Safety ───
# Set to true to disable actual API calls (dry-run mode for testing)
SK_DRY_RUN=false
